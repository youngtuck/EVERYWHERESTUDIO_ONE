{
  "crons": [
    {
      "path": "/api/sentinel-cron",
      "schedule": "0 15 * * *"
    }
  ],
  "functions": {
    "api/sentinel-generate.js": {
      "maxDuration": 60
    },
    "api/sentinel-seed.js": {
      "maxDuration": 30
    },
    "api/sentinel-cron.js": {
      "maxDuration": 60
    },
    "api/generate.js": {
      "maxDuration": 60
    },
    "api/chat.js": {
      "maxDuration": 30
    },
    "api/score.js": {
      "maxDuration": 30
    },
    "api/brand-dna.js": {
      "maxDuration": 30
    },
    "api/brand-dna-from-url.js": {
      "maxDuration": 60
    },
    "api/voice-dna.js": {
      "maxDuration": 30
    },
    "api/visual.js": {
      "maxDuration": 60
    },
    "api/upload-resource.js": {
      "maxDuration": 60
    },
    "api/run-pipeline.js": {
      "maxDuration": 120,
      "includeFiles": "src/lib/agents/prompts/*.md"
    },
    "api/admin-data.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/sw.js", "destination": "/sw.js" },
    { "source": "/manifest.json", "destination": "/manifest.json" },
    { "source": "/icons/(.*)", "destination": "/icons/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    }
  ]
}
